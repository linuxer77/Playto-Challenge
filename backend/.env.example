DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
PLAYTO_TOKEN_SALT=replace-with-unique-token-salt
PLAYTO_TOKEN_MAX_AGE_SECONDS=700000

# Comma-separated list of allowed origins for CORS
# Use * to allow all origins (not recommended for production)
# Example: https://your-app.vercel.app,https://another-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

POSTGRES_DB=playto_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
